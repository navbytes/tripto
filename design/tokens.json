{
  "$schema": "tripto design tokens — single source of truth for Tripto/Sources/Design/Tokens.swift",
  "note": "Edit this file, then run `python3 scripts/gen_tokens.py` to regenerate the Swift constants. Do not hand-edit Tokens.swift.",
  "palette": {
    "light": {
      "ink":       { "hex": "#1A1B2E" },
      "indigo":    { "hex": "#2D2F52" },
      "slate":     { "hex": "#6B6E8F" },
      "mist":      { "hex": "#EEEDF4" },
      "paper":     { "hex": "#FBFAF7" },
      "elevated":  { "hex": "#FFFFFF" },
      "amber":     { "hex": "#E8955A" },
      "amberSoft": { "hex": "#FBEADB" }
    },
    "dark": {
      "ink":       { "hex": "#F2F1F7" },
      "indigo":    { "hex": "#2D2F52" },
      "slate":     { "hex": "#A5A7C0" },
      "mist":      { "hex": "#2A2B40" },
      "paper":     { "hex": "#141522" },
      "elevated":  { "hex": "#1C1D30" },
      "amber":     { "hex": "#E8955A" },
      "amberSoft": { "hex": "#E8955A", "alpha": 0.22 }
    },
    "_comment": "dark set is a conservative, hand-designed variant (RESEARCH_FINDINGS amendment #10) — not an automatic inversion. paper/elevated/ink/slate/mist chosen for contrast; amber is deliberately unchanged (already reads well on dark indigo per the mockups); amberSoft becomes a low-alpha overlay of amber rather than a baked light tint, matching the category 'soft' treatment below."
  },
  "categories": {
    "flight":   {
      "fg": { "hex": "#5B7DB1" },
      "soft": { "light": { "hex": "#E3EAF3" }, "dark": { "hex": "#5B7DB1", "alpha": 0.22 } }
    },
    "hotel":    {
      "fg": { "hex": "#E8955A" },
      "soft": { "light": { "hex": "#FBEADB" }, "dark": { "hex": "#E8955A", "alpha": 0.22 } }
    },
    "activity": {
      "fg": { "hex": "#6E9E7E" },
      "soft": { "light": { "hex": "#E3EEE6" }, "dark": { "hex": "#6E9E7E", "alpha": 0.22 } }
    },
    "food":     {
      "fg": { "hex": "#8B6B9E" },
      "soft": { "light": { "hex": "#EDE5F1" }, "dark": { "hex": "#8B6B9E", "alpha": 0.22 } }
    },
    "transport": {
      "fg": { "hex": "#4F8A87" },
      "soft": { "light": { "hex": "#E0EBEA" }, "dark": { "hex": "#4F8A87", "alpha": 0.22 } }
    }
  },
  "gradients": {
    "dusk": ["#E8955A", "#C96B5B", "#2D2F52"],
    "plum": ["#8B6B9E", "#5B7DB1", "#1A1B2E"],
    "moss": ["#6E9E7E", "#5B7DB1", "#2D2F52"],
    "default": "dusk"
  },
  "spacing": {
    "scale": [2, 4, 8, 12, 16, 22, 32],
    "names": ["xxs", "xs", "sm", "md", "lg", "xl", "xxl"]
  },
  "radii": { "card": 16, "sheet": 22, "pill": 999, "cover": 22 },
  "type": {
    "families": {
      "display": { "font": "Fraunces",    "weights": [500, 600] },
      "body":    { "font": "Sofia Sans",  "weights": [400, 500, 600, 700] },
      "mono":    { "font": "system-monospace" }
    },
    "sizes": {
      "display": { "size": 30, "lineHeight": 34 },
      "title":   { "size": 20 },
      "body":    { "size": 14.5 },
      "caption": { "size": 12.5 }
    }
  }
}
